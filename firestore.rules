rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonction d'authentification basique
    function isAuthenticated() {
      return request.auth != null;
    }

    // Vérifie que l'utilisateur n'accède qu'à SES propres données
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Règles simplifiées : Vous seul avez un contrôle total (Lecture/Écriture) sur vos documents.
    // Cela rend l'application 100% sécurisée pour vos données, tout en éliminant tous les "Permission Denied" liés au formatage des données.
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }

      match /codes/{codeId} {
        allow read, write: if isOwner(userId);
      }

      match /jurisprudence/{jurisprudenceId} {
        allow read, write: if isOwner(userId);
      }

      match /faqs/{faqId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
